{
  "name": "azure-diagram-builder",
  "version": "1.0.0",
  "description": "AI-powered Azure deployment diagram builder with real Microsoft icons, nested groups, and slide-fit layout.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && npx wrangler deploy",
    "deploy:staging": "vite build && npx wrangler deploy --env staging",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "elkjs": "^0.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0"
  },
  "keywords": [
    "azure",
    "diagram",
    "architecture",
    "cloud",
    "deployment",
    "ai"
  ],
  "license": "MIT"
}
